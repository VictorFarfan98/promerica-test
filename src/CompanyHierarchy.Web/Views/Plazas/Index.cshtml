@model CompanyHierarchy.Web.ViewModels.PlazaTreeIndexViewModel
@{
    ViewData["Title"] = "Árbol de plazas";
}

<div class="page-hero mb-4">
    <div>
        <p class="eyebrow mb-1">Jerarquía de la empresa</p>
        <h1 class="display-6 mb-2">Árbol de plazas</h1>
        <p class="text-muted mb-0">Consulta, crea, edita y elimina plazas desde una sola pantalla.</p>
    </div>
    <div class="d-flex gap-2 align-items-start">
        <a class="btn btn-primary" asp-action="Create">Nueva plaza</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<div class="card tree-card">
    <div class="card-body">
        @if (Model.Tree.Count == 0)
        {
            <p class="text-muted mb-0">No hay plazas registradas.</p>
        }
        else
        {
            <partial name="_PlazaNode" model="Model.Tree" />
        }
    </div>
</div>
